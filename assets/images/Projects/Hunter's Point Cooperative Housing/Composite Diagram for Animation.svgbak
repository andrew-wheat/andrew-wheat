  <polygon fill="#FFFFFF" fill-opacity="1" points="251.4154,779.1528 479.503,779.1528 479.503,744.7607 251.4154,744.7607" xmlns="" />
  <text x="259.852868397739" y="770.348397202572" font-family="Arial Narrow" fill="#000000" font-size="23.4782638549805">Retail / Coffee / Services</text>
  <polygon fill="#FFFFFF" fill-opacity="1" points="2021.484,1409.634 2503.064,1409.634 2503.064,1240.242 2021.484,1240.242" xmlns="" />
  <text x="2487.83981709702" y="1265.82948315295" font-family="Arial Narrow" text-anchor="end" fill="#000000" font-size="23.4782638549805">High heat exposure coincides with sustained foot </text>
  <text x="2488.94036068534" y="1292.82948585295" font-family="Arial Narrow" text-anchor="end" fill="#000000" font-size="23.4782638549805">traffic, revealing a gap between environmental </text>
  <text x="2488.1149529941" y="1319.82948855295" font-family="Arial Narrow" text-anchor="end" fill="#000000" font-size="23.4782638549805">performance and urban activity. The project leverages </text>
  <text x="2488.94036068534" y="1346.82949125295" font-family="Arial Narrow" text-anchor="end" fill="#000000" font-size="23.4782638549805">this condition to introduce a shaded, productive </text>
  <text x="2488.57351282257" y="1373.82949395295" font-family="Arial Narrow" text-anchor="end" fill="#000000" font-size="23.4782638549805">corridor that improves comfort while supporting </text>
  <text x="2492.33370341598" y="1400.82949665295" font-family="Arial Narrow" text-anchor="end" fill="#000000" font-size="23.4782638549805">co-located use.</text>
  <polygon fill="#FFFFFF" fill-opacity="1" points="251.4154,859.9009 455.7496,859.9009 455.7496,825.7841 251.4154,825.7841" xmlns="" />
  <text x="259.852868397739" y="851.09653183556" font-family="Arial Narrow" fill="#000000" font-size="23.4782638549805">Pedestrian Movement</text>
  <polygon fill="#FFFFFF" fill-opacity="1" points="242.6244,1316.089 473.6469,1316.089 473.6469,1277.111 242.6244,1277.111" xmlns="" />
  <text x="251.061938369975" y="1302.69893572629" font-family="Arial Narrow" fill="#000000" font-size="23.4782638549805">Continuity + Connections</text>
  <polygon fill="#FFFFFF" fill-opacity="1" points="120.8532,694.7566 464.3145,694.7566 464.3145,520.779 120.8532,520.779" xmlns="" />
  <text x="129.29073015572" y="546.366654120742" font-family="Arial Narrow" font-weight="bold" fill="#000000" font-size="23.4782638549805">2. SCATTERED CONSUMPTION</text>
  <text x="129.29073015572" y="573.366656820742" font-family="Arial Narrow" fill="#000000" font-size="23.4782638549805">c. 2000s-PRESENT</text>
  <text x="129.29073015572" y="627.366662220743" font-family="Arial Narrow" fill="#000000" font-size="23.4782638549805">Rail removed, industry fragmented.</text>
  <text x="129.29073015572" y="654.366664920743" font-family="Arial Narrow" fill="#000000" font-size="23.4782638549805">Consumption becomes dispersed and</text>
  <text x="129.29073015572" y="681.366667620743" font-family="Arial Narrow" fill="#000000" font-size="23.4782638549805">people move across the neighborhood</text>
  <text x="120.499800127956" y="997.969058011474" font-family="Arial Narrow" font-weight="bold" fill="#000000" font-size="23.4782638549805">3. INTERWOVEN PRODUCTION + LIVING</text>
  <text x="120.499800127956" y="1024.96906071147" font-family="Arial Narrow" fill="#000000" font-size="23.4782638549805">FUTURE</text>
  <text x="120.499800127956" y="1078.96906611147" font-family="Arial Narrow" fill="#000000" font-size="23.4782638549805">Production, consumption, and residence </text>
  <text x="120.499800127956" y="1105.96906881147" font-family="Arial Narrow" fill="#000000" font-size="23.4782638549805">co-located within a continuous spatial framework. </text>
  <text x="120.499800127956" y="1132.96907151148" font-family="Arial Narrow" fill="#000000" font-size="23.4782638549805">Movement no longer disperses activity, but thickens it.</text>
  <polygon fill="#FFFFFF" fill-opacity="1" points="242.6244,1235.066 408.6231,1235.066 408.6231,1196.363 242.6244,1196.363" xmlns="" />
  <text x="251.061938369975" y="1221.9508010933" font-family="Arial Narrow" fill="#000000" font-size="23.4782638549805">Nodes of Overlap</text>
  <polygon fill="#FFFFFF" fill-opacity="1" points="279.1667,414.2014 398.0254,414.2014 398.0254,379.8094 279.1667,379.8094" xmlns="" />
  <text x="287.604200636851" y="405.397084828028" font-family="Arial Narrow" fill="#000000" font-size="23.4782638549805">Current Site</text>
  <polygon fill="#FFFFFF" fill-opacity="1" points="131.9506,246.502 420.1096,246.502 420.1096,72.52438 131.9506,72.52438" xmlns="" />
  <text x="140.388141089651" y="98.1120163626299" font-family="Arial Narrow" font-weight="bold" fill="#000000" font-size="23.4782638549805">1. INDUSTRIAL PRODUCTION</text>
  <text x="140.388141089651" y="125.11201906263" font-family="Arial Narrow" fill="#000000" font-size="23.4782638549805">c. 1900s-1970s</text>
  <text x="140.388141089651" y="179.112024462631" font-family="Arial Narrow" fill="#000000" font-size="23.4782638549805">Linear infrastructure</text>
  <text x="140.388141089651" y="206.112027162631" font-family="Arial Narrow" fill="#000000" font-size="23.4782638549805">and heavy industry</text>
  <text x="140.388141089651" y="233.112029862631" font-family="Arial Narrow" fill="#000000" font-size="23.4782638549805">organized by rail</text>
  <polygon fill="#FFFFFF" fill-opacity="1" points="279.1667,331.7377 448.1919,331.7377 448.1919,297.6209 279.1667,297.6209" xmlns="" />
  <text x="363.416809185764" y="322.933379600958" font-family="Arial Narrow" text-anchor="middle" fill="#000000" font-size="23.4782638549805">Historic Rail Lines</text>
